# Rails Environment
RAILS_ENV=production
RACK_ENV=production

# Server Configuration
PORT=3000
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2

# Database Configuration
# PostgreSQL connection - update with your actual values
DATABASE_URL=postgresql://glamova:YOUR_DB_PASSWORD@localhost/glamova_production
GLAMOVA_DATABASE_PASSWORD=YOUR_DB_PASSWORD

# Rails Secret Key Base
# Generate with: rails secret
# Or use: openssl rand -hex 64
SECRET_KEY_BASE=YOUR_SECRET_KEY_BASE_HERE

# CORS Origins - Add your production domain
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# Logging
RAILS_LOG_LEVEL=info
RAILS_LOG_TO_STDOUT=true

# Asset Host (optional)
# ASSET_HOST=https://yourdomain.com
