# Glamova Stock Management - Root .gitignore
# For Rails + React + PostgreSQL stack

# ============================================
# Operating System Files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~

# ============================================
# IDE / Editor
# ============================================
.vscode/
!.vscode/extensions.json
.idea/
.history/
*.sublime-project
*.sublime-workspace
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln

# ============================================
# Logs
# ============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Dependencies
# ============================================
node_modules/
jspm_packages/

# ============================================
# Build outputs
# ============================================
dist/
build/
*.pid

# ============================================
# Temporary files
# ============================================
tmp/
temp/
*.tmp
*.cache

# ============================================
# SSH & Deployment
# ============================================
*.pem
*.key
*.crt
*.p12

# ============================================
# Backup files
# ============================================
*.bak
*.backup
*.old
