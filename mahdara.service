[Unit]
Description=Mahdara Rails Application
After=network.target

[Service]
Type=notify
WatchdogSec=10

User=root
WorkingDirectory=/var/www/mahdara-payment/backend
EnvironmentFile=/var/www/mahdara-payment/backend/.env

ExecStart=/root/.rbenv/bin/rbenv exec bundle exec puma -C config/puma.rb
StandardOutput=append:/var/www/mahdara-payment/backend/log/puma.stdout.log
StandardError=append:/var/www/mahdara-payment/backend/log/puma.stderr.log

Restart=always

[Install]
WantedBy=multi-user.target
